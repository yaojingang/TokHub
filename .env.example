TOKHUB_ENV=development
TOKHUB_ROLE=all
TOKHUB_HOST_PORT=8080
TOKHUB_PUBLIC_URL=http://localhost:8080
TOKHUB_ADMIN_EMAIL=admin@tokhub.local
TOKHUB_ADMIN_PASSWORD=ChangeMe123!
TOKHUB_SECRET_KEY=dev-only-change-this-secret-key-32b
TOKHUB_SEED_MODE=prod
TOKHUB_UPSTREAM_MODE=mock
TOKHUB_DOCS_DIR=docs
TOKHUB_SESSION_SECURE=false
TOKHUB_REGISTRATION_OPEN=true
TOKHUB_EXPOSE_DEV_TOKENS=true
TOKHUB_ADMIN_AGENT_ENABLED=true
DATABASE_URL=postgres://tokhub:tokhub@db:5432/tokhub?sslmode=disable
REDIS_URL=redis://redis:6379/0
NATS_URL=nats://nats:4222
# smtp://user:pass@smtp.example.com:587?from=noreply@example.com&starttls=true
SMTP_URL=
TOKHUB_PROBE_CONCURRENCY=8
TOKHUB_GATEWAY_DEFAULT_QPS=60
# Real-provider RC smoke. Keep TOKHUB_REAL_PROVIDER_KEY out of committed env files.
TOKHUB_REAL_PROVIDER_NAME=OpenAI
TOKHUB_REAL_PROVIDER_TYPE=openai-compatible
TOKHUB_REAL_PROVIDER_ENDPOINT=
TOKHUB_REAL_PROVIDER_MODEL=
TOKHUB_REAL_PROVIDER_KEY=
TOKHUB_REAL_PROVIDER_INPUT_PER_MTOK=
TOKHUB_REAL_PROVIDER_OUTPUT_PER_MTOK=
