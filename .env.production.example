TOKHUB_ENV=production
TOKHUB_ROLE=all
TOKHUB_HOST_PORT=8080
TOKHUB_PUBLIC_URL=https://tokhub.example.com
TOKHUB_ADMIN_EMAIL=admin@example.com
TOKHUB_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
TOKHUB_SECRET_KEY=replace-with-at-least-32-random-characters
TOKHUB_SEED_MODE=prod
TOKHUB_UPSTREAM_MODE=real
TOKHUB_DOCS_DIR=/app/docs
TOKHUB_SESSION_SECURE=true
TOKHUB_REGISTRATION_OPEN=false
TOKHUB_EXPOSE_DEV_TOKENS=false
TOKHUB_ADMIN_AGENT_ENABLED=false
DATABASE_URL=postgres://tokhub:replace-password@postgres.example.com:5432/tokhub?sslmode=require
REDIS_URL=redis://redis.example.com:6379/0
NATS_URL=nats://nats.example.com:4222
# smtp://user:pass@smtp.example.com:587?from=noreply@example.com&starttls=true
SMTP_URL=
TOKHUB_PROBE_CONCURRENCY=8
TOKHUB_GATEWAY_DEFAULT_QPS=60
# Real-provider RC smoke. Provide values via deployment secrets, not committed env files.
TOKHUB_REAL_PROVIDER_NAME=OpenAI
TOKHUB_REAL_PROVIDER_TYPE=openai-compatible
TOKHUB_REAL_PROVIDER_ENDPOINT=
TOKHUB_REAL_PROVIDER_MODEL=
TOKHUB_REAL_PROVIDER_KEY=
TOKHUB_REAL_PROVIDER_INPUT_PER_MTOK=
TOKHUB_REAL_PROVIDER_OUTPUT_PER_MTOK=
# Optional second and third real providers for Phase 12.2.
TOKHUB_REAL_PROVIDER_2_NAME=
TOKHUB_REAL_PROVIDER_2_TYPE=openai-compatible
TOKHUB_REAL_PROVIDER_2_ENDPOINT=
TOKHUB_REAL_PROVIDER_2_MODEL=
TOKHUB_REAL_PROVIDER_2_KEY=
TOKHUB_REAL_PROVIDER_2_INPUT_PER_MTOK=
TOKHUB_REAL_PROVIDER_2_OUTPUT_PER_MTOK=
TOKHUB_REAL_PROVIDER_3_NAME=
TOKHUB_REAL_PROVIDER_3_TYPE=openai-compatible
TOKHUB_REAL_PROVIDER_3_ENDPOINT=
TOKHUB_REAL_PROVIDER_3_MODEL=
TOKHUB_REAL_PROVIDER_3_KEY=
TOKHUB_REAL_PROVIDER_3_INPUT_PER_MTOK=
TOKHUB_REAL_PROVIDER_3_OUTPUT_PER_MTOK=
# Phase 12.2 external delivery checks. Keep secrets out of committed env files.
TOKHUB_PHASE12_SMTP_TEST_EMAIL=
TOKHUB_PHASE12_NOTIFICATION_TYPE=webhook
TOKHUB_PHASE12_NOTIFICATION_TARGET=
TOKHUB_PHASE12_PROVIDER_PUBLIC_VISIBLE=false
