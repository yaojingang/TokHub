{
  "name": "tokhub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test --reporter=line",
    "test:visual": "playwright test tests/*visual*.spec.ts --reporter=line",
    "test:security": "bash deploy/scripts/security-scan.sh",
    "open-source:preflight": "bash deploy/scripts/open-source-preflight.sh",
    "frontend:i18n-check": "bash deploy/scripts/frontend-i18n-check.sh",
    "frontend:ui-contract-check": "bash deploy/scripts/frontend-ui-contract-check.sh",
    "test:ops": "bash deploy/scripts/db-check.sh",
    "test:restore": "bash deploy/scripts/restore-drill.sh",
    "test:preflight": "TOKHUB_SECRET_KEY=ci-production-sample-secret-key-32-bytes TOKHUB_ADMIN_PASSWORD=ci-production-admin-password bash deploy/scripts/preflight.sh --env-file .env.production.example",
    "test:smoke": "bash deploy/scripts/smoke.sh",
    "test:no-demo-smoke": "bash deploy/scripts/no-demo-smoke.sh",
    "test:fresh-prod": "bash deploy/scripts/fresh-prod-check.sh",
    "test:real-provider": "bash deploy/scripts/real-provider-check.sh",
    "release:check": "bash deploy/scripts/release-check.sh",
    "load:prepare": "node deploy/load/prepare-auth.js",
    "load:public": "node deploy/load/public-api.js",
    "load:gateway": "node deploy/load/gateway.js",
    "load:prober": "node deploy/load/prober.js",
    "load:admin": "node deploy/load/admin-query.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.1.2",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.10.1",
    "read-excel-file": "^9.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
